@using Proyecto.Models

<div class="fixed inset-0 bg-black/50 flex items-center justify-center z-50" @onclick="Close">
  <div class="bg-white rounded-lg shadow-lg max-w-3xl w-full mx-4 overflow-hidden transform transition-all duration-300" @onclick:stopPropagation>
    <div class="grid md:grid-cols-2">
      <div class="p-4">
        <img class="w-full h-64 object-cover rounded" src="@Product.ImageUrl" alt="@Product.Name" />
      </div>
      <div class="p-6">
        <h2 class="text-2xl font-semibold">@Product.Name</h2>
        <p class="text-sm text-gray-500 mt-2">@Product.Category</p>
        <p class="mt-4 text-gray-700">@Product.Description</p>
        <div class="mt-6 flex items-center justify-between">
          <div class="text-2xl font-bold text-indigo-600">@Product.Price.ToString("C", System.Globalization.CultureInfo.CurrentCulture)</div>
          <div class="flex gap-2">
            <button class="px-4 py-2 bg-[#1b6ec2] text-white rounded" @onclick="AddToCart">Agregar al carrito</button>
            <button class="px-4 py-2 border rounded" @onclick="Close">Cerrar</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

@code {
    [Parameter]
    public Product Product { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Inject]
    public Proyecto.Services.CartService CartService { get; set; }

    private void AddToCart()
    {
        CartService.Add(Product);
        Close();
    }

    private Task Close()
    {
        return OnClose.InvokeAsync();
    }
}
